---
// Layout กลาง: ใช้ควบคุมเมนู ปุ่มสลับภาษา และ footer ของทุกหน้า
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: "en" | "th";
}
const {
  title = "Kittisak — Digital Designer",
  description = "Selected work of Kittisak Rattanakul.",
  lang = "en",
} = Astro.props;
// lang = "th" สำหรับหน้าไทย และ "en" สำหรับหน้าอังกฤษ
const isThai = lang === "th";
const path = Astro.url.pathname;
// BASE_URL จะเป็น / ระหว่างพัฒนา และ /Portfolio/ บน GitHub Pages
const root = import.meta.env.BASE_URL;
const base = isThai ? `${root}th` : root.replace(/\/$/, "");
// ข้อความเมนูจะแสดงตามภาษาของหน้าปัจจุบัน
const labels = isThai
  ? {
      home: "หน้าแรก",
      profile: "ประวัติ",
      work: "ผลงาน",
      contact: "ติดต่อ",
      talk: "คุยกัน",
      switch: "EN",
      footer: "© 2026 Jeerasak A. สร้างสรรค์จากกรุงเทพฯ",
    }
  : {
      home: "Home",
      profile: "Profile",
      work: "Work",
      contact: "Contact",
      talk: "Let's talk",
      switch: "ไทย",
      footer: "© 2026 Jeerasak A. Crafted in Bangkok.",
    };
// เมนูหลักชี้ไปยัง section ของหน้าแรก เพื่อเลื่อนแบบ one-page
const scrollRoot = isThai ? `${root}th/` : root;
const links = [
  [labels.home, `${scrollRoot}#home`],
  [labels.profile, `${scrollRoot}#profile`],
  [labels.work, `${scrollRoot}#work`],
  [labels.contact, `${scrollRoot}#contact`],
];
// ลิงก์ภาษาเป็น static link ปกติ ไม่ใช้ JavaScript
const languageLink = isThai ? root : `${root}th/`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Noto+Sans+Thai:wght@400;500;700&family=Syne:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class:list={{ 'font-["Noto_Sans_Thai"]': isThai }}>
    <div class="relative min-h-screen overflow-hidden">
      <!-- กริดพื้นหลังแบบ editorial ทำให้ทุกหน้าดูมีเลเยอร์มากขึ้น -->
      <div
        class="page-grid pointer-events-none absolute inset-x-0 top-0 h-[42rem]"
      >
      </div>
      <!-- Header: โลโก้ เมนู และปุ่มสลับภาษา -->
      <header
        class="sticky top-0 z-50 mx-auto flex max-w-7xl items-center justify-between gap-3 border-b border-white/10 bg-ink/95 px-5 py-5 backdrop-blur-md sm:px-6 md:px-10"
      >
        <a
          href={base || "/"}
          class="font-display text-xl font-bold tracking-[-.06em] text-gold sm:text-2xl"
          >Portfolio<span class="text-gold">.</span></a
        >
        <nav class="hidden items-center gap-6 md:flex">
          {
            links.map(([label, href]) => (
              <a
                href={href}
                class:list={[
                  "text-sm font-bold uppercase tracking-[.13em] transition",
                  path === href ||
                  (href.endsWith("/") && path === href.slice(0, -1))
                    ? "text-gold"
                    : "text-stone-500 hover:text-cream",
                ]}
              >
                {label}
              </a>
            ))
          }
        </nav>
        <div class="flex shrink-0 items-center gap-2 sm:gap-3">
          <a
            href={languageLink}
            class="text-xs font-bold uppercase tracking-[.12em] text-stone-400 hover:text-gold sm:text-sm"
            >{labels.switch}</a
          ><a
            href={`${scrollRoot}#contact`}
            class="rounded-full border border-gold/60 px-4 py-2.5 text-xs font-bold uppercase tracking-[.12em] text-gold transition hover:bg-gold hover:text-ink sm:text-sm sm:tracking-[.16em]"
            >{labels.talk}</a
          >
        </div>
      </header>
      <!-- เมนูมือถือ: ใช้ลิงก์ปกติและเลื่อนแนวนอนได้โดยไม่ใช้ JavaScript -->
      <nav
        class="mx-auto flex max-w-7xl gap-6 overflow-x-auto px-5 pb-4 text-sm font-bold uppercase tracking-[.12em] text-stone-500 md:hidden"
      >
        {
          links.map(([label, href]) => (
            <a
              href={href}
              class:list={[
                "shrink-0 py-2 transition",
                path === href ||
                (href.endsWith("/") && path === href.slice(0, -1))
                  ? "text-gold"
                  : "hover:text-cream",
              ]}
            >
              {label}
            </a>
          ))
        }
      </nav>
      <!-- slot คือจุดที่เนื้อหาจากแต่ละหน้าจะถูกวาง -->
      <!-- เลขกำกับด้านข้าง: องค์ประกอบตกแต่งที่แสดงเฉพาะหน้าจอใหญ่ -->
      <div
        class="pointer-events-none fixed bottom-8 left-5 hidden -rotate-90 text-[9px] font-bold uppercase tracking-[.28em] text-stone-600 xl:block"
      >
        Kittisak / Digital practice / 2026
      </div>
      <main class="relative"><slot /></main>
      <!-- Footer กลาง: เปลี่ยน social link ได้ที่จุดเดียว -->
      <footer
        class="mx-auto mt-24 max-w-7xl border-t border-white/10 px-6 py-8 md:px-10"
      >
        <div
          class="flex flex-col gap-4 text-xs text-stone-500 md:flex-row md:items-center md:justify-between"
        >
          <p>{labels.footer}</p><div class="flex gap-5 text-xl">
            <a href="giresnext@gmail.com"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                width="1em"
                height="1em"
                viewBox="0 0 24 24"
                ><path d="M0 0h24v24H0z" fill="none"></path><path
                  fill="currentColor"
                  d="M20 18h-2V9.25L12 13L6 9.25V18H4V6h1.2l6.8 4.25L18.8 6H20m0-2H4c-1.11 0-2 .89-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2"
                ></path></svg
              ></a
            >
            <a href="https://github.com/Girasak77"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                width="1em"
                height="1em"
                viewBox="0 0 24 24"
                ><path d="M0 0h24v24H0z" fill="none"></path><path
                  fill="currentColor"
                  d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"
                ></path></svg
              ></a
            >
            <a href="https://www.instagram.com/_zxnai.p77/"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                width="1em"
                height="1em"
                viewBox="0 0 24 24"
                ><path d="M0 0h24v24H0z" fill="none"></path><path
                  fill="currentColor"
                  d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4zm9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8A1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5a5 5 0 0 1-5 5a5 5 0 0 1-5-5a5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3a3 3 0 0 0 3 3a3 3 0 0 0 3-3a3 3 0 0 0-3-3"
                ></path></svg
              ></a
            >
            <a href="https://www.facebook.com/james.boll.7505"
              ><svg
                xmlns="http://www.w3.org/2000/svg"
                width="1em"
                height="1em"
                viewBox="0 0 24 24"
                ><path d="M0 0h24v24H0z" fill="none"></path><path
                  fill="currentColor"
                  d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95"
                ></path></svg
              ></a
            >
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
