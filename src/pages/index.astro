---
// English home page: mirrors the completed Thai homepage without changing its design intent.
import BaseLayout from "../layouts/BaseLayout.astro";
import ScrollSections from "../components/ScrollSections.astro";
// ใช้ base นี้เพื่อให้ลิงก์ทำงานทั้ง localhost และ GitHub Pages
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Portfolio - Jirasak">
  <section
    id="home"
    class="relative mx-auto flex min-h-[calc(100vh-7rem)] max-w-7xl items-center px-6 py-20 md:px-10 md:py-24"
  >
    <div
      class="grid w-full items-center gap-14 lg:grid-cols-[1.05fr_.95fr] lg:gap-20"
    >
      <!-- English introduction: change this copy only when you want to update the English profile. -->
      <div class="relative z-10 lg:pl-4">
        <p class="section-rule mb-6">Welcome to my portfolio</p>
        <h1
          class="hero-title font-display text-5xl font-bold leading-[1.08] text-cream sm:text-6xl lg:text-7xl"
        >
          Hello,<br />my name is <span class="text-gold">Jirasak.</span>
        </h1>
        <p
          class="mt-7 font-display text-xl tracking-[-.03em] text-gold md:text-2xl"
        >
          Web developer & full-stack developer
        </p>
        <p class="mt-8 max-w-lg text-sm leading-8 text-stone-400 md:text-base">
          I am an IT student interested in building websites and end-to-end
          applications, from frontend interfaces to backend systems. I am
          committed to learning new technologies and developing practical skills
          to create products that work in the real world.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href={`${base}contact`}
            class="rounded-sm bg-gold px-6 py-3 text-xs font-bold tracking-[.12em] text-ink transition hover:bg-cream"
            >Contact me <span class="ml-1">→</span></a
          ><a
            href={`${base}portfolio`}
            class="rounded-sm border border-white/15 px-6 py-3 text-xs font-bold tracking-[.12em] text-cream transition hover:border-gold hover:text-gold"
            >View projects</a
          >
        </div>
        <!-- Same social destinations as the Thai page. -->
        <div class="mt-10 flex items-center gap-5 text-5xl text-gold">
          <a href="giresnext@gmail.com"
            ><svg
              xmlns="http://www.w3.org/2000/svg"
              width="1em"
              height="1em"
              viewBox="0 0 24 24"
              ><path d="M0 0h24v24H0z" fill="none"></path><path
                fill="currentColor"
                d="M20 18h-2V9.25L12 13L6 9.25V18H4V6h1.2l6.8 4.25L18.8 6H20m0-2H4c-1.11 0-2 .89-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2"
              ></path></svg
            ></a
          >
          <a href="https://github.com/Girasak77"
            ><svg
              xmlns="http://www.w3.org/2000/svg"
              width="1em"
              height="1em"
              viewBox="0 0 24 24"
              ><path d="M0 0h24v24H0z" fill="none"></path><path
                fill="currentColor"
                d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"
              ></path></svg
            ></a
          >
          <a href="https://www.instagram.com/_zxnai.p77/"
            ><svg
              xmlns="http://www.w3.org/2000/svg"
              width="1em"
              height="1em"
              viewBox="0 0 24 24"
              ><path d="M0 0h24v24H0z" fill="none"></path><path
                fill="currentColor"
                d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4zm9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8A1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5a5 5 0 0 1-5 5a5 5 0 0 1-5-5a5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3a3 3 0 0 0 3 3a3 3 0 0 0 3-3a3 3 0 0 0-3-3"
              ></path></svg
            ></a
          >
          <a href="https://www.facebook.com/james.boll.7505"
            ><svg
              xmlns="http://www.w3.org/2000/svg"
              width="1em"
              height="1em"
              viewBox="0 0 24 24"
              ><path d="M0 0h24v24H0z" fill="none"></path><path
                fill="currentColor"
                d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95"
              ></path></svg
            ></a
          >
        </div>
      </div>
      <!-- Hero portrait shared with the Thai home page. -->
      <div class="relative mx-auto w-full max-w-md lg:max-w-[30rem]">
        <div class="absolute -inset-8 rounded-full bg-gold/10 blur-3xl">
        </div><div
          class="relative overflow-hidden rounded-sm border border-gold/40 bg-panel p-2 shadow-[0_0_60px_rgba(217,174,84,.13)]"
        >
          <img
            src={`${base}images/hero-coding-portrait.png`}
            alt="่jeerasak"
            class="aspect-[4/5] w-full object-cover object-center"
          /><div
            class="absolute inset-x-2 bottom-2 flex items-center justify-between border-t border-white/10 bg-ink/75 px-4 py-3 backdrop-blur-sm"
          >
            <span
              class="text-[10px] font-bold uppercase tracking-[.18em] text-gold"
              >Building ideas into code</span
            ><span
              class="h-2 w-2 rounded-full bg-gold shadow-[0_0_12px_#d9ae54]"
            ></span>
          </div>
        </div><span
          class="absolute -right-3 -top-7 font-display text-7xl text-gold/30"
          ></span
        >
      </div>
    </div>
  </section>
  <ScrollSections />
</BaseLayout>
