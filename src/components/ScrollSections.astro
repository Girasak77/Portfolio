---
// Section เต็มรูปแบบสำหรับหน้าแรกแบบเลื่อนยาว
// โครงสร้าง Skills, Projects และ Contact คงรูปแบบเดียวกับหน้าเดิม
import ProjectCard from "./ProjectCard.astro";

interface Props {
  lang?: "en" | "th";
}

const { lang = "en" } = Astro.props;
const isThai = lang === "th";
const assetBase = import.meta.env.BASE_URL;

const skills = [
  ["Tailwind CSS", "TW", "Frontend"],
  ["JavaScript", "JS", "Language"],
  ["TypeScript", "TS", "Language"],
  ["Node.js", "ND", "Backend"],
  ["Deno", "DN", "Runtime"],
  ["Bun", "BN", "Runtime"],
  ["SQL", "SQL", "Database"],
  ["Prisma", "PR", "ORM"],
  ["Astro", "AS", "Framework"],
  ["Vue", "VU", "Frontend"],
  ["Nuxt", "NX", "Framework"],
  ["React", "RC", "Library"],
  ["SvelteKit", "SK", "Framework"],
  ["DevOps", "DO", "Infrastructure"],
  ["Bootstrap", "BS", "UI"],
  ["Cloudflare Pages", "CF", "Deploy"],
  ["Git & GitHub", "GH", "Version control"],
  ["HTML & CSS", "HC", "Foundation"],
];

const projects = [
  ["Tala Studio", "Brand identity and e-commerce", "01", "from-[#644426] via-[#302011] to-[#101011]"],
  ["Morrow Journal", "Editorial platform", "02", "from-[#382c54] via-[#151f3e] to-[#101011]"],
  ["Aera Objects", "Digital art direction", "03", "from-[#1d4d4b] via-[#142525] to-[#101011]"],
  ["Oasis Hotel", "Hospitality and booking", "04", "from-[#694536] via-[#281b19] to-[#101011]"],
  ["Pond Records", "Music label website", "05", "from-[#2a465c] via-[#152331] to-[#101011]"],
  ["Nula Finance", "Product design", "06", "from-[#5c4d2a] via-[#25200f] to-[#101011]"],
];

const text = isThai
  ? {
      profileLabel: "01 / ประวัติ",
      profileTitle: "Developer",
      profileText:
        "นักศึกษา IT ที่สนใจการพัฒนาเว็บไซต์และระบบงานครบวงจร ตั้งแต่ Frontend ไปจนถึง Backend พร้อมเรียนรู้เทคโนโลยีใหม่และสร้างงานที่ใช้งานได้จริง.",
      skillsLabel: "02 / Technical toolbox",
      skillsTitle: "Skills ที่ผมใช้\nสร้างงานให้เกิดขึ้นจริง",
      workLabel: "03 / ผลงานที่คัดสรร",
      workTitle: "ผลงานของผม",
      contactLabel: "04 / มาร่วมงานกัน",
      contactTitle: "มาสร้างโปรเจกต์ด้วยกัน",
      contactText: "หากมีโปรเจกต์ ไอเดีย หรือโอกาสฝึกงานที่น่าสนใจ ยินดีพูดคุยและเรียนรู้ไปด้วยกันครับ",
      name: "ชื่อของคุณ",
      project: "เล่าเกี่ยวกับโปรเจกต์",
      send: "ส่งข้อความ",
    }
  : {
      profileLabel: "01 / Jirasak Eakchantuek",
      profileTitle: "Developer",
      profileText:
        "An Information Technology student passionate about web and software development. I continuously build full-stack skills across JavaScript, C#, HTML, CSS, and databases.",
      skillsLabel: "02 / Technical toolbox",
      skillsTitle: "Skills I use\nto build real projects",
      workLabel: "03 / Selected projects",
      workTitle: "My projects",
      contactLabel: "04 / Let’s work together",
      contactTitle: "Let’s build a project together",
      contactText: "I am looking for internship opportunities and opportunities to grow my full-stack development skills. If you have an interesting project or idea, I would be happy to talk and learn together.",
      name: "Your name",
      project: "Tell me about your project",
      send: "Send message",
    };
---

<!-- Profile: คงโครงสร้างรูปและเนื้อหาแนะนำตัวแบบหน้า About เดิม -->
<section id="profile" class="scroll-section mx-auto max-w-7xl px-6 pt-16 md:px-10 md:pt-24">
  <p class="eyebrow">{text.profileLabel}</p>
  <div class="mt-7 grid gap-10 lg:grid-cols-[.8fr_1.2fr]">
    <div class="aspect-[4/5] overflow-hidden rounded-sm bg-[#1b1712]">
      <img src={`${assetBase}images/S__31408131.jpg`} alt="Profile portrait" class="h-full w-full object-cover" />
    </div>
    <div class="flex flex-col justify-end">
      <p class="section-rule mb-5">Profile / Bangkok, Thailand</p>
      <h2 class="section-title whitespace-pre-line">{text.profileTitle}</h2>
      <p class="mt-8 max-w-xl text-base leading-8 text-stone-400">{text.profileText}</p>
      <div class="mt-8 flex flex-wrap gap-2">
        <span class="tag-pill">Frontend</span><span class="tag-pill">Backend</span><span class="tag-pill">Digital product</span>
      </div>
    </div>
  </div>
</section>

<!-- Skills: คง grid การ์ดทักษะแบบเต็มจากหน้า About เดิม -->
<section class="mx-auto mt-28 max-w-7xl px-6 md:px-10">
  <div class="mb-10">
    <p class="eyebrow mb-3">{text.skillsLabel}</p>
    <h2 class="section-title whitespace-pre-line">{text.skillsTitle}</h2>
  </div>
  <div class="panel-glow rounded-sm p-4 md:p-6">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6">
      {skills.map(([name, label, category], index) => (
        <article class="group relative min-h-40 overflow-hidden rounded-sm border border-white/8 bg-ink/70 p-4 transition duration-300 hover:-translate-y-1 hover:border-gold/60 hover:bg-[#1a1711]">
          <span class="absolute right-3 top-3 text-[9px] font-bold tracking-widest text-stone-600">0{index + 1}</span>
          <div class="flex h-full flex-col justify-between">
            <span class="grid h-11 w-11 place-items-center rounded-full border border-gold/30 bg-gold/10 font-display text-sm font-bold text-gold">{label}</span>
            <div>
              <p class="text-[9px] font-bold uppercase tracking-[.18em] text-stone-500">{category}</p>
              <h3 class="mt-2 font-display text-lg font-bold leading-tight text-cream">{name}</h3>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Work: คงจำนวนและรูปแบบ ProjectCard แบบหน้า Work เดิม -->
<section id="work" class="scroll-section mx-auto mt-28 max-w-7xl px-6 md:px-10">
  <p class="eyebrow">{text.workLabel}</p>
  <div class="mt-5 flex flex-wrap items-end justify-between gap-6">
    <h2 class="section-title">{text.workTitle}</h2>
    <span class="text-xs text-gold">All</span>
  </div>
  <div class="mt-14 grid gap-x-6 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
    {projects.map(([title, category, number, color]) => <ProjectCard title={title} category={category} number={number} color={color} />)}
  </div>
</section>

<!-- Contact: คงข้อความและฟอร์มติดต่อจากหน้า Contact เดิม -->
<section id="contact" class="scroll-section mx-auto mt-28 max-w-7xl px-6 pb-8 md:px-10">
  <p class="eyebrow">{text.contactLabel}</p>
  <div class="mt-5 grid gap-14 lg:grid-cols-2">
    <div>
      <h2 class="section-title">{text.contactTitle}</h2>
      <p class="mt-7 max-w-md leading-7 text-stone-400">{text.contactText}</p>
      <a href="mailto:giresnext@gmail.com" class="mt-10 block font-display text-2xl text-gold underline decoration-gold/30 underline-offset-8">giresnext@gmail.com</a>
    </div>
    <form class="rounded-sm border border-white/10 bg-panel p-6 md:p-8">
      <label class="block text-xs text-stone-400">{text.name}<input class="mt-2 w-full border-b border-white/15 bg-transparent py-3 text-cream outline-none focus:border-gold" placeholder={isThai ? "ชื่อที่อยากให้เรียก" : "How should I call you?"} /></label>
      <label class="mt-7 block text-xs text-stone-400">Email<input type="email" class="mt-2 w-full border-b border-white/15 bg-transparent py-3 text-cream outline-none focus:border-gold" placeholder="you@company.com" /></label>
      <label class="mt-7 block text-xs text-stone-400">{text.project}<textarea class="mt-2 min-h-28 w-full border-b border-white/15 bg-transparent py-3 text-cream outline-none focus:border-gold" placeholder={isThai ? "เรากำลังจะสร้างอะไร?" : "What would you like to build?"}></textarea></label>
      <button type="button" class="mt-8 rounded-full bg-gold px-6 py-3 text-xs font-bold tracking-widest text-ink">{text.send}</button>
    </form>
  </div>
</section>
