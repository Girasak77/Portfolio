---
// ส่วนเนื้อหาสำหรับหน้าแรกแบบเลื่อนยาว (one-page) ใช้ได้ทั้งไทยและอังกฤษ
interface Props {
  lang?: "en" | "th";
}

const { lang = "en" } = Astro.props;
const isThai = lang === "th";
const base = import.meta.env.BASE_URL;

const content = isThai
  ? {
      profileLabel: "01 / ประวัติ",
      profileTitle: "คนที่อยู่เบื้องหลังโค้ด",
      profileText:
        "นักศึกษา IT ที่สนใจการพัฒนาเว็บไซต์และระบบงานครบวงจร ตั้งแต่ Frontend ไปจนถึง Backend พร้อมเรียนรู้เทคโนโลยีใหม่และสร้างงานที่ใช้งานได้จริง.",
      workLabel: "02 / ผลงาน",
      workTitle: "ผลงานที่คัดสรร",
      contactLabel: "03 / ติดต่อ",
      contactTitle: "มาสร้างโปรเจกต์ด้วยกัน",
      contactText:
        "หากมีโปรเจกต์ ไอเดีย หรือโอกาสฝึกงานที่น่าสนใจ ติดต่อผมได้เสมอครับ",
      email: "ส่งอีเมล",
    }
  : {
      profileLabel: "01 / Profile",
      profileTitle: "The person behind the code",
      profileText:
        "An IT student interested in building useful websites and end-to-end applications, from frontend interfaces to backend systems.",
      workLabel: "02 / Work",
      workTitle: "Selected projects",
      contactLabel: "03 / Contact",
      contactTitle: "Let’s build something useful",
      contactText:
        "Have a project, idea, or internship opportunity? I would be happy to connect and learn together.",
      email: "Send an email",
    };

const projects = ["Portfolio Website", "Full-stack Practice", "UI / UX Experiments"];
---

<!-- Profile section: เมนู Profile จะเลื่อนมาที่ส่วนนี้ -->
<section id="profile" class="scroll-section mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
  <div class="grid items-center gap-10 lg:grid-cols-[.8fr_1.2fr]">
    <div class="overflow-hidden rounded-sm border border-gold/30 bg-panel p-2">
      <img
        src={`${base}images/S__31408131.jpg`}
        alt={isThai ? "รูปโปรไฟล์" : "Profile portrait"}
        class="aspect-[4/5] w-full object-cover"
      />
    </div>
    <div>
      <p class="eyebrow">{content.profileLabel}</p>
      <h2 class="section-title mt-4">{content.profileTitle}</h2>
      <p class="mt-7 max-w-xl text-sm leading-8 text-stone-400 md:text-base">
        {content.profileText}
      </p>
      <div class="mt-8 flex flex-wrap gap-2">
        <span class="tag-pill">Frontend</span>
        <span class="tag-pill">Backend</span>
        <span class="tag-pill">Full-stack</span>
      </div>
    </div>
  </div>
</section>

<!-- Work section: เมนู Work จะเลื่อนมาที่ส่วนนี้ -->
<section id="work" class="scroll-section border-y border-white/10 bg-panel/40">
  <div class="mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
    <p class="eyebrow">{content.workLabel}</p>
    <h2 class="section-title mt-4">{content.workTitle}</h2>
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {
        projects.map((project, index) => (
          <article class="rounded-sm border border-white/10 bg-ink/70 p-6 transition hover:-translate-y-1 hover:border-gold/60">
            <span class="font-display text-4xl text-gold/50">0{index + 1}</span>
            <h3 class="mt-12 text-xl font-bold text-cream">{project}</h3>
            <p class="mt-3 text-sm leading-7 text-stone-400">
              {isThai ? "พื้นที่สำหรับใส่รายละเอียดผลงานของคุณ" : "A space for your project description and results."}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<!-- Contact section: เมนู Contact จะเลื่อนมาที่ส่วนนี้ -->
<section id="contact" class="scroll-section mx-auto max-w-7xl px-6 py-24 md:px-10 md:py-32">
  <div class="max-w-3xl">
    <p class="eyebrow">{content.contactLabel}</p>
    <h2 class="section-title mt-4">{content.contactTitle}</h2>
    <p class="mt-7 max-w-xl text-sm leading-8 text-stone-400 md:text-base">
      {content.contactText}
    </p>
    <a href="mailto:giresnext@gmail.com" class="mt-9 inline-flex rounded-sm bg-gold px-6 py-3 text-sm font-bold text-ink transition hover:bg-cream">
      {content.email} →
    </a>
  </div>
</section>
