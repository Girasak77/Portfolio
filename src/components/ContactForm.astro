---
interface Props {
  lang?: "en" | "th";
}

const { lang = "en" } = Astro.props;
const isThai = lang === "th";
const labels = isThai
  ? {
      name: "ชื่อของคุณ",
      namePlaceholder: "ชื่อที่อยากให้เรียก",
      email: "อีเมล",
      emailPlaceholder: "you@company.com",
      message: "เล่าเกี่ยวกับโปรเจกต์",
      messagePlaceholder: "อยากคุยเรื่องโปรเจกต์ ฝึกงาน หรือโอกาสแบบไหน?",
      send: "ส่งข้อความ",
      subject: "ติดต่อจากเว็บไซต์ Portfolio ของ Jeerasak",
      alert: "กรุณากรอกชื่อ อีเมล และข้อความก่อนส่งครับ",
    }
  : {
      name: "Your name",
      namePlaceholder: "How should I call you?",
      email: "Email",
      emailPlaceholder: "you@company.com",
      message: "Tell me about your project",
      messagePlaceholder: "Project, internship, or opportunity details",
      send: "Send message",
      subject: "Message from Jeerasak Portfolio",
      alert: "Please fill in your name, email, and message before sending.",
    };
---

<form
  class="rounded-sm border border-white/10 bg-panel p-6 md:p-8"
  data-contact-form
  data-subject={labels.subject}
  data-alert={labels.alert}
>
  <label class="block text-xs text-stone-400">
    {labels.name}
    <input
      name="name"
      required
      class="mt-2 w-full border-b border-white/15 bg-transparent py-3 text-cream outline-none focus:border-gold"
      placeholder={labels.namePlaceholder}
    />
  </label>
  <label class="mt-7 block text-xs text-stone-400">
    {labels.email}
    <input
      name="email"
      type="email"
      required
      class="mt-2 w-full border-b border-white/15 bg-transparent py-3 text-cream outline-none focus:border-gold"
      placeholder={labels.emailPlaceholder}
    />
  </label>
  <label class="mt-7 block text-xs text-stone-400">
    {labels.message}
    <textarea
      name="message"
      required
      class="mt-2 min-h-28 w-full border-b border-white/15 bg-transparent py-3 text-cream outline-none focus:border-gold"
      placeholder={labels.messagePlaceholder}></textarea>
  </label>
  <button
    type="submit"
    class="mt-8 rounded-full bg-gold px-6 py-3 text-xs font-bold tracking-widest text-ink transition hover:bg-cream"
  >
    {labels.send}
  </button>
</form>

<script is:inline>
  document.querySelectorAll("[data-contact-form]").forEach((form) => {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const name = String(data.get("name") || "").trim();
      const email = String(data.get("email") || "").trim();
      const message = String(data.get("message") || "").trim();

      if (!name || !email || !message) {
        alert(form.dataset.alert);
        return;
      }

      const subject = encodeURIComponent(form.dataset.subject || "Portfolio contact");
      const body = encodeURIComponent(
        `Name: ${name}\nEmail: ${email}\n\nMessage:\n${message}`
      );
      window.location.href = `mailto:giresnext@gmail.com?subject=${subject}&body=${body}`;
    });
  });
</script>
